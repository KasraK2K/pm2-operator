{
  "name": "pm2-operator",
  "version": "1.0.0",
  "private": true,
  "description": "PM2 Operator is a focused operations console for managing PM2 hosts, processes, dashboards, and live logs over SSH.",
  "keywords": [
    "pm2",
    "operator",
    "monitoring",
    "logs",
    "ssh",
    "dashboard",
    "nodejs",
    "devops"
  ],
  "author": "Kasra Karami <Kasra.Karami.KK@gmail.com>",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev --workspace @pm2-operator/server\" \"npm run dev --workspace @pm2-operator/web\"",
    "test": "npm run test --workspace @pm2-operator/server",
    "prisma:generate": "npm run prisma:generate --workspace @pm2-operator/server",
    "prisma:migrate": "npm run prisma:migrate --workspace @pm2-operator/server",
    "prisma:deploy": "npm run prisma:deploy --workspace @pm2-operator/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
